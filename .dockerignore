build
.svelte-kit
.git
.github
.vscode
.idea
.playwright-mcp
.claude
test-results
playwright-report
coverage
*.png
*.jpg
*.jpeg
*.gif
.env
.env.*
!.env.example
.DS_Store
README.md
CLAUDE.md
Makefile
memory
scripts/bench-*.mjs
tests
playwright.config.ts
playwright-report
Dockerfile
.dockerignore
